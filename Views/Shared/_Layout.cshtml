<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Event Ease SolutionsX</title>

    <script type="importmap"></script>

    <!-- Bootstrap + Custom Styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventEase.styles.css" asp-append-version="true" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-light">
    <div class="d-flex vh-100">

        <!-- Vertical Sidebar - Red & Purple Theme -->
        <div class="bg-white border-end shadow-sm d-flex flex-column" style="width: 280px;">

            <!-- Logo / Brand -->
            <div class="p-4 border-bottom">
                <a href="/" class="d-flex align-items-center text-dark text-decoration-none">
                    <i class="bi bi-calendar2-check-fill text-danger fs-2 me-3"></i>
                    <span class="fw-bold fs-4">Event Ease SolutionsX</span>
                </a>
            </div>

            <!-- Navigation Menu -->
            <nav class="flex-grow-1 p-3">
                <ul class="nav flex-column fw-medium">
                    <li class="nav-item mb-2">
                        <a class="nav-link text-dark px-3 py-3 rounded-3"
                           asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-3"></i> Home
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link text-dark px-3 py-3 rounded-3"
                           asp-controller="Venue" asp-action="Index">
                            <i class="bi bi-geo-alt me-3"></i> Venues
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link text-dark px-3 py-3 rounded-3"
                           asp-controller="Event" asp-action="Index">
                            <i class="bi bi-calendar-event me-3"></i> Events
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link text-dark px-3 py-3 rounded-3"
                           asp-controller="Booking" asp-action="Index">
                            <i class="bi bi-ticket me-3"></i> Bookings
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Sidebar Footer -->
            <div class="p-4 border-top mt-auto">
                <div class="d-flex gap-3">
                    <a href="#" class="btn btn-outline-danger flex-fill fw-medium">
                        Log in
                    </a>
                    <a href="#" class="btn flex-fill fw-medium text-white"
                       style="background: linear-gradient(135deg, #9F1239, #6B21A8); border: none;">
                        Get Started
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="flex-grow-1 d-flex flex-column">

            <!-- Top Bar -->
            <header class="bg-white shadow-sm border-bottom px-4 py-3">
                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <h3 class="fw-bold mb-0">@ViewData["Title"]</h3>
                        <small class="text-muted">
                            Event Management Dashboard
                        </small>
                    </div>

                    <div class="text-end">
                        <div class="fw-semibold">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            Johannesburg, South Africa
                        </div>

                        <small class="text-muted">
                            @DateTime.Now.ToString("dddd, dd MMMM yyyy")
                        </small>
                    </div>

                </div>
            </header>

            <!-- Page Content -->
            <main class="flex-grow-1 p-4 overflow-auto" style="background:#f5f6fa;">
                <div class="container-fluid">

                    <!-- Welcome Banner -->
                    <div class="mb-4 p-4 rounded-4 text-white shadow"
                         style="background:linear-gradient(135deg,#9F1239,#6B21A8);">
                        <h2 class="fw-bold mb-1">Welcome to Event Ease SolutionsX</h2>
                        <p class="mb-0">
                            Manage your venues, events and bookings in one place.
                        </p>
                    </div>

                    <!-- Page Content -->
                    <div class="card border-0 shadow-lg rounded-4">
                        <div class="card-body p-4">
                            @RenderBody()
                        </div>
                    </div>

                </div>
            </main>

            <!-- Footer -->
            <footer class="bg-white border-top py-4 px-4 text-muted small">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        &copy; @DateTime.Now.Year Event Ease SolutionsX. All rights reserved.
                    </div>
                    <div class="d-flex gap-4">
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">Privacy</a>
                        <a href="#" class="text-decoration-none text-muted">About Us</a>
                        <a href="#" class="text-decoration-none text-muted">Careers</a>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>