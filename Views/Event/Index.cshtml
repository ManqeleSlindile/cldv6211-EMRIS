@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<h1>Events</h1>

<!-- ===================== FILTERS ===================== -->
<form asp-action="Index" method="get" class="mb-3">

    <div class="row">

        <!-- Event Type -->
        <div class="col-md-3">
            <label>Event Type</label>
            <select name="eventTypeId" class="form-control">
                <option value="">All Event Types</option>

                @foreach (var type in ViewBag.EventTypes)
                {
                    <option value="@type.EventTypeId">
                        @type.Name
                    </option>
                }

            </select>
        </div>

        <!-- Start Date -->
        <div class="col-md-3">
            <label>Start Date</label>
            <input type="date"
                   name="startDate"
                   class="form-control" />
        </div>

        <!-- End Date -->
        <div class="col-md-3">
            <label>End Date</label>
            <input type="date"
                   name="endDate"
                   class="form-control" />
        </div>

        <!-- Availability -->
        <div class="col-md-2">
            <label>Availability</label>

            <div class="form-check mt-2">
                <input class="form-check-input"
                       type="checkbox"
                       name="availableOnly"
                       value="true" />

                <label class="form-check-label">
                    Available Only
                </label>
            </div>

        </div>

        <div class="col-md-1 d-flex align-items-end">
            <button type="submit"
                    class="btn btn-primary">
                Filter
            </button>
        </div>

    </div>

</form>

<hr />

<p>
    <a asp-action="Create" class="btn btn-success">
        Create New Event
    </a>
</p>

<table class="table table-bordered table-striped">

    <thead>

        <tr>

            <th>Event Name</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Event Type</th>
            <th>Venue</th>
            <th>Description</th>
            <th>Actions</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.EventName</td>

                <td>@item.StartDate.ToString("dd MMM yyyy HH:mm")</td>

                <td>@item.EndDate.ToString("dd MMM yyyy HH:mm")</td>

                <td>@item.EventType?.Name</td>

                <td>@item.Venue?.VenueName</td>

                <td>@item.Description</td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.EventID">
                        Edit
                    </a> |

                    <a asp-action="Details"
                       asp-route-id="@item.EventID">
                        Details
                    </a> |

                    <a asp-action="Delete"
                       asp-route-id="@item.EventID">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>