@model EventEase.Models.Event

@{
    ViewData["Title"] = "Edit Event";
}

<h1>Edit Event</h1>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="EventID" />

            <div class="form-group mb-3">
                <label asp-for="EventName"></label>
                <input asp-for="EventName" class="form-control" />
                <span asp-validation-for="EventName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StartDate"></label>
                <input asp-for="StartDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EndDate"></label>
                <input asp-for="EndDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description"></label>
                <input asp-for="Description" class="form-control" />
            </div>

            <!-- Venue -->
            <div class="form-group mb-3">
                <label asp-for="VenueID"></label>

                <select asp-for="VenueID" class="form-control">

                    @foreach (var venue in ViewBag.Venues)
                    {
                        <option value="@venue.VenueID">@venue.VenueName</option>
                    }

                </select>

            </div>

            <!-- Event Type -->
            <div class="form-group mb-3">
                <label asp-for="EventTypeId"></label>

                <select asp-for="EventTypeId" class="form-control">

                    @foreach (var type in ViewBag.EventTypes)
                    {
                        <option value="@type.EventTypeId">@type.Name</option>
                    }

                </select>

            </div>

            <button class="btn btn-primary">Save</button>

        </form>

    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
